{
  "name": "yapper",
  "version": "1.1.0",
  "description": "Local-first dictation for Windows",
  "type": "module",
  "scripts": {
    "postinstall": "svelte-kit sync",
    "kill:dev-port": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Get-NetTCPConnection -LocalPort 1420 -State Listen -ErrorAction SilentlyContinue | Select-Object -ExpandProperty OwningProcess -Unique | ForEach-Object { Stop-Process -Id $_ -Force -ErrorAction SilentlyContinue }\"",
    "kill:dev-port:unix": "bash -c 'p=$(lsof -ti :1420); [ -n \"$p\" ] && kill -9 $p || true'",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "bundle:python": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/bundle-windows-python-runtime.ps1",
    "bundle:python:mac": "bash scripts/bundle-macos-python-runtime.sh",
    "pack": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pack-with-updater-signing.ps1",
    "pack:raw": "tauri build && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-latest-json.ps1",
    "pack:release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pack-with-updater-signing.ps1 -Release",
    "pack:debug": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pack-with-updater-signing.ps1 -Debug",
    "pack:mac": "bash scripts/pack-with-updater-signing.sh",
    "pack:release:mac": "bash scripts/pack-with-updater-signing.sh --release"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-global-shortcut": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
