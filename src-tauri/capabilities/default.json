{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for Yapper",
  "windows": ["main", "hud"],
  "permissions": [
    "core:default",
    "core:app:allow-set-app-theme",
    "core:app:allow-default-window-icon",
    "core:window:allow-set-icon",
    "allow-sync-windows-taskbar-icon",
    "dialog:default",
    "global-shortcut:default",
    "updater:default",
    "process:default"
  ]
}
